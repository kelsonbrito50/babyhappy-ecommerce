# ============================================================
# BabyHappy E-Commerce — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production-use-a-long-random-string

DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

DEBUG=True

# ── Database ─────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://babyhappy:babyhappy@localhost:5432/babyhappy

# ── Cache / Sessions ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=BabyHappy <noreply@babyhappyjp.com.br>
SERVER_EMAIL=errors@babyhappyjp.com.br

# ── Cielo Payment Gateway ────────────────────────────────────
CIELO_MERCHANT_ID=your-cielo-merchant-id
CIELO_MERCHANT_KEY=your-cielo-merchant-key
# Set to False in production to use real Cielo API
CIELO_SANDBOX=True

# ── Sentry (optional) ────────────────────────────────────────
# Leave empty to disable Sentry error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Admin URL (production hardening) ─────────────────────────
# Change this to a secret path to protect the admin interface
ADMIN_URL=admin/

# ── Static / Media files (S3) ────────────────────────────────
# Required if using django-storages with S3 for production static/media files.
# Leave blank to serve locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
